# CloudEmu Docker Compose 环境变量
# cp .env.example .env 启用 
# 部署前按需修改，docker compose 启动时自动加载此文件

# ── 端口映射（宿主机端口）──
CP_PORT=8080
PG_PORT=5432
REDIS_PORT=6379
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001

# ── PostgreSQL ──
PG_USER=postgres
PG_PASSWORD=postgres
PG_DB=cloudemu

# ── Redis ──
# REDIS_PASS=              # Redis 密码，无密码留空

# ── JWT 签名密钥（生产环境务必更换）──
JWT_SECRET=change-me-in-production

# ── MinIO ──
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=cloudemu

# ── 日志 ──
LOG_LEVEL=info
# LOG_JSON=true            # 生产环境建议启用 JSON 格式

# ── 前端地址（密码重置链接用),请设置为外部浏览器能够访问的前端地址──
FRONTEND_BASE_URL=http://cloudemu:5173

# ── SMTP 邮件 用于邮箱验证码和找回密码邮件 ──
SMTP_HOST=smtp.qq.com
SMTP_PORT=587
SMTP_USER=your-email@qq.com
SMTP_PASS=your-auth-code
SMTP_FROM="CloudEmu <noreply@example.com>"
SMTP_USE_TLS=true

# ── Worker ──
WORKER_ADDR=worker:9090                    # Worker gRPC 监听地址，默认 :9090
LIVEKIT_HOST=http://localhost:7880   # LiveKit 服务地址（外部部署，必须配置）
LIVEKIT_API_KEY=<your_api_key>       # LiveKit API Key（必须配置）
LIVEKIT_API_SECRET=<your_api_secret> # LiveKit API Secret（必须配置）

# ── Coturn TURN 中继 ──
# TURN_SECRET 必须与 livekit.yaml 中 turn.shared_key 保持一致
TURN_EXTERNAL_IP=<your_external_ip>
TURN_SECRET=change-this-turn-secret-in-production