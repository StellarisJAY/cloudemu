# CloudEmu 本地开发环境变量
# 使用方法：cp .env.example .env  然后按需修改
# 注意：.env 文件不提交到 Git，仅用于本地调试

# ── 服务监听地址 ──
ADDR=:8080

# ── PostgreSQL 连接串 ──
DSN=host=localhost user=postgres password=postgres dbname=cloudemu port=5432 sslmode=disable TimeZone=Asia/Shanghai

# ── Redis ──
REDIS_ADDR=localhost:6379
# REDIS_PASS=              # Redis 密码，无密码留空
# REDIS_DB=0                # Redis DB 编号（业务数据：captcha/room state/limiter），默认 0
# WORKER_REDIS_DB=1         # Redis DB 编号（Worker 注册与调度专用），默认 1

# ── JWT 签名密钥（生产环境务必更换）──
JWT_SECRET=dev-secret-change-in-production

# ── MinIO 对象存储 ──
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=cloudemu
# MINIO_USE_SSL=true        # 是否使用 SSL 连接，默认 false（不启用）

# ── Worker Agent ──
# WORKER_ADDR=:9090         # Worker gRPC 监听地址，默认 :9090
# WORKER_REDIS_DB=1         # Worker Redis DB 编号（Worker 注册专用），默认 1
# LOG_LEVEL=info            # 日志级别 debug/info/warn/error
LIVEKIT_HOST=http://localhost:7880
LIVEKIT_API_KEY=<your_api_key>
LIVEKIT_API_SECRET=<your_api_secret>
EMURUNNER_PATH=./emurunner

# ── SMTP 邮件发送（可选，不配置则不发送邮件，开发环境可通过日志获取 token）──
# SMTP_HOST=smtp.qq.com
# SMTP_PORT=587
# SMTP_USER=your-email@qq.com
# SMTP_PASS=your-auth-code
# SMTP_FROM="CloudEmu <noreply@example.com>"
# SMTP_USE_TLS=true
# FRONTEND_BASE_URL=http://localhost:5173